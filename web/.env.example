# -----------------------------------------------------------------------------
# Zentro Next.js frontend — copy to .env.local and edit.
# -----------------------------------------------------------------------------

# Where the FastAPI backend lives. The Next.js server-side code talks to this
# directly; the browser never hits it. Prefer 127.0.0.1 over "localhost" so
# Node's fetch and uvicorn agree on IPv4 loopback (avoids random "fetch failed").
ZIMS_API_URL=http://127.0.0.1:8000

# The API path prefix the backend registers its routes under.
ZIMS_API_PREFIX=/api/v1

# Session cookie secret — set any long random string in production.
# Used to sign the cookie that carries the JWT back to the browser.
AUTH_COOKIE_NAME=zentro_session

# Public site URL (used for Open Graph, canonical URLs, etc).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
