# =============================================================================
# Zentro Insurance Management System (ZIMS)
# Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in real values:
#   cp .env.example .env
#
# For local dev WITHOUT Docker:
#   - Use SQLite: DATABASE_URL=sqlite:///./zims.db
#   - Skip Redis: leave REDIS_URL as localhost (or blank)
#
# For Docker development / production:
#   - PostgreSQL and Redis are provisioned by docker-compose.yml
#   - These defaults work out of the box with `make docker-up`
# =============================================================================

# --- Application ---
APP_NAME=Zentro ZIMS
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# --- Database ---
# PostgreSQL (Docker default — matches docker-compose service name)
DATABASE_URL=postgresql+psycopg2://zims:zims@localhost:5432/zims

# SQLite fallback for quick local dev without Docker:
# DATABASE_URL=sqlite:///./zims.db

# Connection pool tuning (PostgreSQL only; ignored for SQLite)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# --- Redis ---
# Cache, Celery broker, rate-limit store
REDIS_URL=redis://localhost:6379/0

# --- Celery (Phase 3) ---
# Defaults to REDIS_URL if left blank
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# --- JWT / Security ---
# Required. Use at least 32 random characters in development; production requires
# a strong unique value (see app/core/config.py — 48+ chars, no placeholders).
SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- OpenAI (AI Assistant) ---
# Leave blank for fallback (heuristic) replies
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Twilio (WhatsApp) ---
# Leave SID + TOKEN blank to run in "stub" mode (logs outgoing messages
# instead of hitting Twilio). Fill both to enable real sending.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# --- Scheduler ---
RENEWAL_WINDOW_DAYS=30
RENEWAL_JOB_HOUR=2
RENEWAL_JOB_MINUTE=0
BIRTHDAY_JOB_HOUR=8
BIRTHDAY_JOB_MINUTE=0

# When true, runs `alembic upgrade head` on API startup (typical in Docker prod).
RUN_ALEMBIC_ON_STARTUP=false

# --- Document uploads ---
UPLOAD_DIR=./var/uploads
MAX_DOCUMENT_SIZE_MB=10

# --- Excel import ---
MAX_IMPORT_FILE_SIZE_MB=5

# --- Internal integrations ---
# Shared key accepted by internal product-to-product calls such as LeadRadar -> ZIMS.
ZIMS_INTERNAL_API_KEY=

# --- Stripe (Billing) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_GROWTH_PRICE_ID=
STRIPE_PRO_PRICE_ID=

# Note: the Next.js frontend has its own env file at web/.env.local
# (see web/.env.example). It talks to this backend via ZIMS_API_URL there.
